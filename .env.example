# ============================================================
# .env.example — copy to .env and fill in real values
# DO NOT commit .env to git
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000

# ── Auth ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret

# ── Database ─────────────────────────────────────────────────
# Option A: full connection string (used by the main app & preferred)
DATABASE_URL=postgres://pguser:pgpassword@127.0.0.1:5432/kesh_kyb_kyc_dev

# Option B: individual vars (used by db:migrate / db:seed scripts as fallback)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=pguser
PGPASSWORD=pgpassword
PGDATABASE=kesh_kyb_kyc_dev

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000,https://kyc-dev.kesh.co.id

# ── File uploads ─────────────────────────────────────────────
# Public base URL of this API (used to build file download URLs)
BASE_URL=https://kyc-api-dev.kesh.co.id
# Directory (relative to CWD or absolute) where uploads are stored
UPLOAD_DIR=uploads
# Maximum upload size in megabytes
MAX_UPLOAD_MB=20

# ── Redis (reserved — docker-compose includes Redis but the app does not yet use it directly) ──
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Risk engine (uncomment if risk env vars are wired back in) ──
# RISK_SCORE_THRESHOLD_HIGH=70
# RISK_SCORE_THRESHOLD_MEDIUM=40
